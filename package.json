{
  "name": "varken",
  "version": "2.2.4",
  "description": "Standalone application to aggregate data from the Plex ecosystem into time-series databases",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "clean": "rm -rf dist .reports node_modules logs data",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "docker-test:start": "docker compose -f docker-compose.test.yaml up -d",
    "docker-test:stop": "docker compose -f docker-compose.test.yaml down",
    "docker-test:check": "./scripts/check-data.sh",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Navino16/Varken.git"
  },
  "keywords": [
    "plex",
    "sonarr",
    "radarr",
    "tautulli",
    "influxdb",
    "grafana",
    "monitoring",
    "metrics"
  ],
  "author": "navino16",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Navino16/Varken/issues"
  },
  "homepage": "https://github.com/Navino16/Varken#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "@influxdata/influxdb-client-apis": "^1.35.0",
    "@types/pg": "^8.20.0",
    "axios": "^1.15.0",
    "influx": "^5.12.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "winston": "^3.17.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  }
}
